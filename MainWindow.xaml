<Window x:Class="Paw_somePasswordProtector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Paw_somePasswordProtector"
        mc:Ignorable="d" WindowStyle="None" MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Title="Paw-somePasswordProtector" Height="450" Width="800" ResizeMode="NoResize">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0" />
    </WindowChrome.WindowChrome>
    <Grid>
        <!-- Define Pawsome Grid Layout-->
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition />
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        
        <!-- Menu Bar -->
        <Rectangle Fill="LightCyan" />
        <TextBlock Name="tbTitle" Text="Paw-some Password Protector" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <Button Name="btnClose" Content="X" Width="25" Height="20" Margin="5"
                Background="Transparent" BorderBrush="Transparent"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Click="btnClose_Click"/>
        <!-- Content Pane -->
        
        <!-- First Popup Window-->
        <Grid Name="Grid1" Grid.Row="1" IsEnabled="True" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition>
                </RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Name="tbPrompt" Text="Enter My Dog's Name to Access Passwords" 
                        Height="50" FontSize="35" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Name="tbxInput" Text="Enter Here..." TextAlignment="Center"
                        FontSize="20" Width="300" Height="40" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Name="tbOutput" Text=""  
                        Height="30" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
            <Button Grid.Row="2" Name="btnSubmit" Content="Authenticate"
                    Width="120" Height="50" VerticalAlignment="Center"
                    Click="btnSubmit_Click" FontSize="18" />
        </Grid>
        
        <!-- Password Store Panel-->
        <Grid Name="Grid2" Grid.Row="1" IsEnabled="False" Visibility="Hidden">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" FontSize="35" Margin="5" 
           Text="Authentication Successful!"/>
                <TextBlock Name="tb_Pass1" HorizontalAlignment="Center" FontSize="20" Margin="5" 
           Text="Pasword1"/>
                <TextBlock Name="tb_Pass2" HorizontalAlignment="Center" FontSize="20" Margin="5" 
           Text="Pasword2"/>
                <TextBlock Name="tb_Pass3" HorizontalAlignment="Center" FontSize="20" Margin="5" 
           Text="Pasword3"/>
                <TextBlock Name="tb_Pass4" HorizontalAlignment="Center" FontSize="20" Margin="5" 
           Text="Pasword4"/>
                <TextBlock Name="tb_Pass5" HorizontalAlignment="Center" FontSize="20" Margin="5" 
           Text="Pasword5"/>
            </StackPanel>
        </Grid>
        
        <!-- Footer -->
        <Rectangle Grid.Row="2" Fill="LightCyan" />
        <TextBlock Grid.Row="2" Name="tbFooter" Text="@Berchonyl2026" 
                   FontSize="15" HorizontalAlignment="Right" VerticalAlignment="Center" 
                   Margin="1"/>
    </Grid>
</Window>
